  {
    "bindings": {
      "shift-tab shift-y": "zed::Minimize"
    }
  },
  {
    "bindings": {
      "tab j": "zed::Minimize"
    }
  },
  {
    "bindings": {
      "alt-shift-u": "zed::Minimize"
    }
  },
  {
    "context": "SettingsWindow",
    "bindings": {
      "alt-shift-g": "settings_editor::Minimize"
    }
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      "alt-t": "project_panel::Open"
    }
  },
  {
    "context": "(Editor && edit_prediction_conflict)",
    "bindings": {
      "tab enter": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-,": "agent::ToggleFocus"
    }
  },
  {
